      "label": "Date Applied",
      "type": "date",
      "fieldset": "Status & dates"
    },
    {
      "name": "issued_date",
      "label": "Issued",
      "type": "date",
      "fieldset": "Status & dates"
    },
    {
      "name": "expires",
      "label": "Expires",
      "type": "date",
      "required": true,
      "fieldset": "Status & dates"
    },
    {
      "name": "fee",
      "label": "Permit Fee",
      "type": "currency",
      "fieldset": "Status & dates"
    }
