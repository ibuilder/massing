      "label": "Type",
      "type": "select",
      "options": [
        "Building",
        "Foundation",
        "Demolition",
        "Electrical",
        "Plumbing",
        "Mechanical / HVAC",
        "Fire / Life-Safety",
        "Grading / Sitework",
        "Right-of-Way",
        "Elevator",
        "Certificate of Occupancy"
      ],
      "fieldset": "Permit"
    },
    {
      "name": "authority",
      "label": "Authority (AHJ)",
      "type": "text",
      "fieldset": "Permit"
    },
    {
      "name": "number",
      "label": "Permit #",
      "type": "text",
      "fieldset": "Permit"
    },
    {
      "name": "status",
      "label": "Status",
      "type": "select",
      "options": [
        "Applied",
        "Under Review",
        "Issued",
        "Expired",
        "Closed"
