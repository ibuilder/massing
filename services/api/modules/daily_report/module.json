{
  "key": "daily_report",
  "name": "Daily Reports",
  "section": "Field",
  "icon": "☼",
  "ref_prefix": "DR",
  "title_field": "report_date",
  "pinnable": false,
  "fields": [
    {
      "name": "report_date",
      "label": "Date",
      "type": "date",
      "required": true
    },
    {
      "name": "weather",
      "label": "Weather",
      "type": "select",
      "options": ["Clear", "Partly Cloudy", "Overcast", "Rain", "Snow", "Wind", "Fog", "Extreme Heat", "Freezing"]
    },
    {
      "name": "temp_f",
      "label": "Temp (°F)",
      "type": "number"
    },
    {
      "name": "weather_impact",
      "label": "Weather Impact",
      "type": "select",
      "options": ["None", "Minor Delay", "Half-Day Lost", "Full-Day Lost", "Stoppage"]
    },
    {
      "name": "manpower",
      "label": "Manpower Count",
      "type": "number"
    },
    {
      "name": "work_performed",
      "label": "Work Performed",
      "type": "textarea"
    },
    {
      "name": "deliveries",
      "label": "Deliveries Received",
      "type": "textarea"
    },
    {
      "name": "equipment_on_site",
      "label": "Equipment On Site",
      "type": "textarea"
    },
    {
      "name": "delays",
      "label": "Delays / Disruptions",
      "type": "textarea"
    },
    {
      "name": "visitors",
      "label": "Visitors / Inspections",
      "type": "textarea"
    },
    {
      "name": "safety_note",
      "label": "Safety Observations",
      "type": "textarea"
    },
    {
      "name": "photos",
      "label": "Photo Links",
      "type": "textarea"
    },
    {
      "name": "crew_total",
      "label": "Crew (total)",
      "type": "rollup",
      "source_module": "manpower_log",
      "source_field": "count",
      "op": "sum"
    },
    {
      "name": "equip_hours",
      "label": "Equipment hrs",
      "type": "rollup",
      "source_module": "equipment_log",
      "source_field": "hours",
      "op": "sum"
    }
  ],
  "list_columns": ["report_date", "weather", "manpower", "weather_impact"],
  "workflow": {
    "initial": "draft",
    "states": [
      "draft",
      "submitted"
    ],
    "transitions": [
      {
        "from": "draft",
        "to": "submitted",
        "action": "submit",
        "party": [
          "GC",
          "Subcontractor"
        ]
      }
    ]
  }
}
