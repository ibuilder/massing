{
  "key": "submittal",
  "name": "Submittals",
  "section": "Engineering",
  "icon": "\u25a4",
  "ref_prefix": "SUB",
  "title_field": "title",
  "pinnable": true,
  "fields": [
    {
      "name": "title",
      "label": "Title",
      "type": "text",
      "required": true
    },
    {
      "name": "spec_section",
      "label": "Spec Section",
      "type": "text",
      "required": true
    },
    {
      "name": "type",
      "label": "Type",
      "type": "select",
      "options": [
        "Product Data",
        "Shop Drawing",
        "Sample",
        "Mock-up",
        "Certificate",
        "Test Report",
        "Calculations",
        "O&M Manual",
        "Warranty"
      ]
    },
    {
      "name": "rev",
      "label": "Revision",
      "type": "number"
    },
    {
      "name": "responsible_contractor",
      "label": "Responsible Contractor",
      "type": "text"
    },
    {
      "name": "disposition",
      "label": "Disposition",
      "type": "select",
      "options": [
        "Approved",
        "Approved as Noted",
        "Revise & Resubmit",
        "Rejected",
        "For Record Only"
      ]
    },
    {
      "name": "lead_time_days",
      "label": "Lead Time (days)",
      "type": "number"
    },
    {
      "name": "required_on_site",
      "label": "Required On Site",
      "type": "date"
    },
    {
      "name": "date_received",
      "label": "Date Received",
      "type": "date"
    },
    {
      "name": "date_returned",
      "label": "Date Returned",
      "type": "date"
    },
    {
      "name": "cost_code",
      "label": "Cost Code",
      "type": "reference",
      "module": "cost_code"
    },
    {
      "name": "transmittal",
      "label": "Transmittal",
      "type": "reference",
      "module": "transmittal"
    },
    {
      "name": "drawing",
      "label": "Drawing / detail",
      "type": "reference",
      "module": "drawing"
    }
  ],
  "list_columns": [
    "type",
    "spec_section",
    "rev",
    "required_on_site"
  ],
  "workflow": {
    "initial": "draft",
    "states": [
      "draft",
      "submitted",
      "gc_review",
      "ae_review",
      "returned",
      "closed"
    ],
    "transitions": [
      {
        "from": "draft",
        "to": "submitted",
        "action": "submit",
        "party": [
          "Subcontractor"
        ]
      },
      {
        "from": "submitted",
        "to": "gc_review",
        "action": "begin_review",
        "party": [
          "GC"
        ]
      },
      {
        "from": "gc_review",
        "to": "ae_review",
        "action": "forward",
        "party": [
          "GC"
        ]
      },
      {
        "from": "gc_review",
        "to": "draft",
        "action": "return_to_sub",
        "party": [
          "GC"
        ]
      },
      {
        "from": "ae_review",
        "to": "returned",
        "action": "disposition",
        "party": [
          "Consultant"
        ]
      },
      {
        "from": "returned",
        "to": "closed",
        "action": "close",
        "party": [
          "GC"
        ]
      },
      {
        "from": "returned",
        "to": "draft",
        "action": "revise_resubmit",
        "party": [
          "GC"
        ]
      }
    ]
  },
  "revisable": true
}
