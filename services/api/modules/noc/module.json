{
  "key": "noc",
  "name": "Notifications of Change",
  "section": "Change Management",
  "icon": "⚐",
  "ref_prefix": "NOC",
  "title_field": "subject",
  "pinnable": true,
  "fields": [
    {
      "name": "subject",
      "label": "Subject",
      "type": "text",
      "required": true,
      "fieldset": "Notice"
    },
    {
      "name": "description",
      "label": "Description",
      "type": "textarea",
      "fieldset": "Notice"
    },
    {
      "name": "direction",
      "label": "Owner Direction",
      "type": "select",
      "options": [
        "Proceed & Pricing",
        "Pricing Only",
        "Do Not Proceed"
      ],
      "fieldset": "Notice"
    },
    {
      "name": "reason",
      "label": "Reason",
      "type": "select",
      "options": [
        "Design Change",
        "Owner Request",
        "Unforeseen Condition",
        "Field Conflict",
        "Code / AHJ"
      ],
      "fieldset": "Notice"
    },
    {
      "name": "received_from",
      "label": "Received From",
      "type": "text",
      "fieldset": "Notice"
    },
    {
      "name": "cost_estimate",
      "label": "Est. Cost",
      "type": "currency",
      "fieldset": "Impact"
    },
    {
      "name": "schedule_days",
      "label": "Schedule Days",
      "type": "number",
      "fieldset": "Impact"
    },
    {
      "name": "issued_date",
      "label": "Issued",
      "type": "date",
      "fieldset": "Dates"
    },
    {
      "name": "response_due",
      "label": "Response Due",
      "type": "date",
      "fieldset": "Dates"
    }
  ],
  "workflow": {
    "initial": "issued",
    "states": [
      "issued",
      "returned",
      "closed"
    ],
    "transitions": [
      {
        "from": "issued",
        "to": "returned",
        "action": "return_direction",
        "party": [
          "Owner",
          "OwnersRep"
        ]
      },
      {
        "from": "returned",
        "to": "closed",
        "action": "close",
        "party": [
          "GC"
        ]
      }
    ]
  },
  "list_columns": [
    "cost_estimate",
    "schedule_days"
  ]
}
