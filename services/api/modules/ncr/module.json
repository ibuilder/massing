{
  "key": "ncr",
  "name": "Non-Conformance Reports",
  "section": "Quality",
  "icon": "⚠",
  "ref_prefix": "NCR",
  "title_field": "subject",
  "pinnable": true,
  "fields": [
    {
      "name": "subject",
      "label": "Non-conformance",
      "type": "text",
      "required": true
    },
    {
      "name": "description",
      "label": "Description",
      "type": "textarea"
    },
    {
      "name": "disposition",
      "label": "Disposition",
      "type": "select",
      "options": [
        "Rework",
        "Repair",
        "Use-as-is",
        "Reject"
      ]
    },
    {
      "name": "inspection",
      "label": "Source Inspection",
      "type": "reference",
      "module": "inspection"
    },
    {
      "name": "severity",
      "label": "Severity",
      "type": "select",
      "options": [
        "Minor",
        "Major",
        "Critical"
      ],
      "required": true
    },
    {
      "name": "root_cause",
      "label": "Root Cause",
      "type": "textarea"
    },
    {
      "name": "corrective_action",
      "label": "Corrective Action",
      "type": "textarea"
    },
    {
      "name": "due_date",
      "label": "Due Date",
      "type": "date"
    }
  ],
  "workflow": {
    "initial": "open",
    "states": [
      "closed",
      "dispositioned",
      "open"
    ],
    "transitions": [
      {
        "from": "open",
        "to": "dispositioned",
        "action": "disposition",
        "party": [
          "GC"
        ]
      },
      {
        "from": "dispositioned",
        "to": "closed",
        "action": "close",
        "party": [
          "GC"
        ]
      }
    ]
  },
  "list_columns": [
    "severity",
    "disposition",
    "due_date"
  ],
  "close_requires_attachment": [
    "closed"
  ]
}
