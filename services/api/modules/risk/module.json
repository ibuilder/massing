      },
      {
        "from": "open",
        "to": "accepted",
        "action": "accept",
        "party": [
          "Owner",
          "OwnersRep"
        ]
      },
      {
        "from": "mitigating",
        "to": "closed",
        "action": "close",
        "party": [
          "GC",
          "OwnersRep"
        ]
      },
      {
        "from": "mitigating",
        "to": "open",
        "action": "reopen",
        "party": [
          "GC"
        ]
      }
    ]
  },
  "list_columns": [
    "category",
    "probability",
    "impact",
    "response_strategy",
    "cost_exposure"
  ],
  "workspace": "construction"
