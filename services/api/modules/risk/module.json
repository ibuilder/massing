      "label": "Cost Exposure",
      "type": "currency"
    },
    {
      "name": "schedule_days",
      "label": "Schedule Days",
      "type": "number"
    },
    {
      "name": "trigger",
      "label": "Trigger / warning signs",
      "type": "textarea"
    },
    {
      "name": "mitigation",
      "label": "Mitigation (Plan A)",
      "type": "textarea"
    },
    {
      "name": "contingency",
      "label": "Contingency (Plan B)",
      "type": "textarea"
    },
    {
      "name": "owner",
      "label": "Owner",
      "type": "text"
    },
    {
      "name": "due_date",
      "label": "Review Date",
      "type": "date"
    }
