{
  "key": "inspection",
  "name": "Inspections",
  "section": "Quality",
  "icon": "✓",
  "ref_prefix": "INS",
  "title_field": "subject",
  "pinnable": true,
  "fields": [
    {
      "name": "subject",
      "label": "Inspection",
      "type": "text",
      "required": true
    },
    {
      "name": "location",
      "label": "Location",
      "type": "text"
    },
    {
      "name": "result",
      "label": "Result",
      "type": "select",
      "options": [
        "Pass",
        "Fail",
        "Conditional"
      ]
    },
    {
      "name": "inspection_type",
      "label": "Type",
      "type": "select",
      "options": [
        "Pre-Installation",
        "In-Progress",
        "Final",
        "Agency",
        "Commissioning"
      ]
    },
    {
      "name": "inspector",
      "label": "Inspector",
      "type": "text"
    },
    {
      "name": "date",
      "label": "Date",
      "type": "date",
      "required": true
    },
    {
      "name": "agency",
      "label": "Agency",
      "type": "text"
    },
    {
      "name": "spec_section",
      "label": "Spec Section",
      "type": "text"
    },
    {
      "name": "reinspection_date",
      "label": "Re-inspection Date",
      "type": "date"
    },
    {
      "name": "photos",
      "label": "Photos",
      "type": "textarea"
    },
    {
      "name": "ncr_count",
      "label": "# NCRs",
      "type": "rollup",
      "source_module": "ncr",
      "source_field": "subject",
      "op": "count"
    },
    {
      "name": "deficiency_count",
      "label": "# Deficiencies",
      "type": "rollup",
      "source_module": "deficiency",
      "source_field": "subject",
      "op": "count"
    }
  ],
  "workflow": {
    "initial": "scheduled",
    "states": [
      "failed",
      "passed",
      "scheduled"
    ],
    "transitions": [
      {
        "from": "scheduled",
        "to": "passed",
        "action": "pass",
        "party": [
          "GC"
        ]
      },
      {
        "from": "scheduled",
        "to": "failed",
        "action": "fail",
        "party": [
          "GC"
        ]
      }
    ]
  },
  "list_columns": [
    "inspection_type",
    "result",
    "date"
  ]
}
