{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-navigate",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-file",
    "fs:allow-write-file",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/aec-bim-server", "sidecar": true }]
    }
  ]
}
