{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Massing",
  "version": "0.3.165",
  "identifier": "com.ibuilder.aecbim",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Massing",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "headers": {
        "Cross-Origin-Opener-Policy": "same-origin",
        "Cross-Origin-Embedder-Policy": "require-corp"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE5OTIzMTFBOEQ5OTUyNTQKUldSVVVwbU5HakdTcVUzY2NpZVBVL0NNcmtQOEUzTVlwcUl0L1JXZnRuaFp0RkJ3L2czRUlvQmwK",
      "endpoints": [
        "https://github.com/ibuilder/massing/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/aec-bim-server"
    ]
  }
}
