{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AEC BIM Platform",
  "version": "0.1.0",
  "identifier": "com.ibuilder.aecbim",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AEC BIM Platform",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "// note": "COOP/COEP keep the WebView cross-origin isolated so web-ifc's multithreaded WASM (SharedArrayBuffer) works inside Tauri, mirroring the nginx + Vite headers.",
      "headers": {
        "Cross-Origin-Opener-Policy": "same-origin",
        "Cross-Origin-Embedder-Policy": "require-corp"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"],
    "externalBin": ["binaries/aec-bim-server"]
  }
}
